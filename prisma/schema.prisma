// Reminder data model — see docs/04-DATA-MODEL.md for design notes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────
// Users & Auth
// ────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  displayName     String
  avatarUrl       String?
  timezone        String    @default("UTC")
  isAdmin         Boolean   @default(false)
  isBanned        Boolean   @default(false)
  bannedReason    String?
  emailVerifiedAt DateTime?
  // 设计稿"勿扰"时段；24h "HH:MM" 字符串。两个都为 null = 不勿扰。
  dndStart        String?
  dndEnd          String?
  // 通知声偏好；"default" / "wechat" / "ding" / "off"。前端把这串
  // 传给 Web Audio 选音色，服务端只是存。
  notificationSound String  @default("default")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  ownedGroups        Group[]             @relation("GroupOwner")
  memberships        GroupMember[]
  remindersCreated   Reminder[]          @relation("ReminderCreator")
  remindersAssigned  Reminder[]          @relation("ReminderAssignee")
  claims             Claim[]
  completions        Completion[]
  comments           Comment[]
  reactions          Reaction[]
  pokesSent          Poke[]              @relation("PokeFrom")
  pokesReceived      Poke[]              @relation("PokeTo")
  streakDays         StreakDay[]
  shieldCard         ShieldCard?
  pokeSetting        PokeSetting?
  tags               Tag[]
  pushSubscriptions  PushSubscription[]
  notifications      Notification[]
  reportsFiled       Report[]            @relation("Reporter")
  reportsResolved    Report[]            @relation("Resolver")
  adminLogs          AdminLog[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  attachments        Attachment[]

  @@index([email])
  @@index([isAdmin])
}

// ────────────────────────────────────────────
// Auth tokens (one-time, ours — separate from Auth.js's adapter tables
// because we use credentials provider with JWT sessions; see CLAUDE.md)
// ────────────────────────────────────────────

model EmailVerification {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// MailLog — every outgoing email is recorded. In dev/test the DevMailer
// only writes here (no SMTP); in production the SmtpMailer writes here
// AND hands off to nodemailer. This gives admin/audit visibility and
// lets E2E tests find verification/reset links without a real inbox.

model MailLog {
  id          String       @id @default(uuid())
  toAddress   String
  subject     String
  body        String // plain-text body; HTML may follow in a later phase
  category    MailCategory
  refId       String? // optional ref (e.g. EmailVerification.id, PasswordReset.id)
  sentAt      DateTime?
  errorReason String?
  createdAt   DateTime     @default(now())

  @@index([toAddress, createdAt])
  @@index([category, createdAt])
}

enum MailCategory {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  GROUP_INVITE
  OTHER
}

// ────────────────────────────────────────────
// Groups & Membership
// ────────────────────────────────────────────

model Group {
  id          String   @id @default(uuid())
  name        String
  coverEmoji  String?
  // 手绘 icon 名（hf-icons 集合：bird/book/letterA/dumbbell/house/...）
  // null = 用 coverEmoji 兜底。
  iconName    String?
  // 群头像底色 hex（CSS 变量也行）。null = 自动选 7 色之一。
  tintColor   String?
  // 群节奏描述（"每天 6:30 · 拍照打卡"），HfGroupDetail 副标题。
  cadence     String?
  // 公开/私密；公开群可以被搜到。默认私密。
  visibility  GroupVisibility @default(PRIVATE)
  ownerId     String
  isDisbanded Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members   GroupMember[]
  reminders Reminder[]
  invites   InviteToken[]

  @@index([ownerId])
  @@index([visibility])
}

enum GroupVisibility {
  PRIVATE
  PUBLIC
}

model GroupMember {
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
}

enum GroupRole {
  OWNER
  MEMBER
}

// ────────────────────────────────────────────
// Reminders & Related
// ────────────────────────────────────────────

model Reminder {
  id          String             @id @default(uuid())
  title       String
  description String?
  creatorId   String
  // 主接手；null = 群里所有人都可以认领。HfReminderDetail 用这字段
  // 决定"指派给"那一行渲染谁。
  assigneeId  String?
  groupId     String? // null = 私人提醒
  visibility  ReminderVisibility
  // 优先级；HfCreate "! 高优先" 提示。HIGH 提醒会更早出现在 Today。
  priority    ReminderPriority   @default(NORMAL)
  // 文字位置（HfCreate "位置"）。地图坐标后续再加。
  locationName   String?
  // true = 完成时强制带图（"收下，发个图"）
  proofRequired  Boolean          @default(false)
  dueAt       DateTime?
  repeatRule  String? // RRULE 字符串
  // Cron 写入：上一次 REMINDER_DUE 通知触发对应的 dueAt（避免重复推送 +
  // 给 RRULE 推进逻辑当游标）
  lastDueNotifiedAt DateTime?
  status      ReminderStatus     @default(ACTIVE)
  isPinned    Boolean            @default(false)
  isDeleted   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  creator     User          @relation("ReminderCreator", fields: [creatorId], references: [id])
  assignee    User?         @relation("ReminderAssignee", fields: [assigneeId], references: [id])
  group       Group?        @relation(fields: [groupId], references: [id])
  claims      Claim[]
  completions Completion[]
  comments    Comment[]
  reactions   Reaction[]
  pokes       Poke[]
  tags        ReminderTag[]
  attachments Attachment[]

  @@index([creatorId])
  @@index([assigneeId])
  @@index([groupId])
  @@index([dueAt])
  @@index([status])
}

enum ReminderVisibility {
  PRIVATE
  GROUP
}

enum ReminderStatus {
  ACTIVE
  DONE
  SKIPPED
}

enum ReminderPriority {
  NORMAL
  HIGH
}

// 多人可认领同一条提醒
model Claim {
  id         String   @id @default(uuid())
  reminderId String
  userId     String
  claimedAt  DateTime @default(now())

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([reminderId, userId])
  @@index([userId])
}

// 完成记录（一条提醒可被同一人多次完成，如重复提醒）
model Completion {
  id          String   @id @default(uuid())
  reminderId  String
  userId      String
  completedAt DateTime @default(now())
  mediaUrl    String?
  note        String?

  reminder    Reminder     @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  attachments Attachment[]

  @@index([reminderId])
  @@index([userId, completedAt])
}

model Comment {
  id         String   @id @default(uuid())
  reminderId String
  userId     String
  content    String
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([reminderId])
}

model Reaction {
  id         String   @id @default(uuid())
  reminderId String
  userId     String
  emoji      String
  createdAt  DateTime @default(now())

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([reminderId, userId, emoji])
}

// ────────────────────────────────────────────
// Pokes (拍拍 — 独立消息系统)
// ────────────────────────────────────────────

model Poke {
  id         String    @id @default(uuid())
  fromId     String
  toId       String
  reminderId String? // 可选；用户开关允许时可为 null
  tone       PokeTone
  message    String?
  sentAt     DateTime  @default(now())
  readAt     DateTime?
  // "拍回去 一起做"链；HfL2Poked 的 secondary CTA。
  replyToId  String?

  from     User      @relation("PokeFrom", fields: [fromId], references: [id])
  to       User      @relation("PokeTo", fields: [toId], references: [id])
  reminder Reminder? @relation(fields: [reminderId], references: [id])
  replyTo  Poke?     @relation("PokeReply", fields: [replyToId], references: [id])
  replies  Poke[]    @relation("PokeReply")

  @@index([toId, sentAt])
  @@index([fromId, toId, sentAt]) // 限额查询用
  @@index([replyToId])
}

enum PokeTone {
  ALMOST // 差一点点
  THINKING // 想到你了
  NO_RUSH // 不急慢慢来
}

// 用户对拍拍的偏好设置
model PokeSetting {
  userId            String  @id
  allowUnlinkedPoke Boolean @default(false)
  doNotDisturb      Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ────────────────────────────────────────────
// Streaks & Shield Cards
// ────────────────────────────────────────────

model StreakDay {
  id     String          @id @default(uuid())
  userId String
  date   DateTime        @db.Date
  status StreakDayStatus

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

enum StreakDayStatus {
  DONE
  SKIPPED
  PROTECTED
  MISSED
}

model ShieldCard {
  userId       String    @id
  count        Int       @default(0)
  lastEarnedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ────────────────────────────────────────────
// Tags
// ────────────────────────────────────────────

model Tag {
  id       String @id @default(uuid())
  userId   String
  name     String
  iconName String // 对应 hf-icons 里的 svg name
  color    String

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders ReminderTag[]

  @@unique([userId, name])
}

model ReminderTag {
  reminderId String
  tagId      String

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reminderId, tagId])
}

// ────────────────────────────────────────────
// Invites
// ────────────────────────────────────────────

model InviteToken {
  id           String    @id @default(uuid())
  groupId      String
  token        String    @unique
  createdById  String
  expiresAt    DateTime
  usedByUserId String?
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ────────────────────────────────────────────
// Push Notifications
// ────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  payload   Json
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

enum NotificationType {
  POKE_RECEIVED
  REMINDER_DUE
  REMINDER_COMPLETED_BY_OTHER
  REMINDER_CLAIMED_BY_OTHER
  GROUP_INVITED
  STREAK_MILESTONE
  COMMENT_NEW
  REACTION_NEW
}

// ────────────────────────────────────────────
// Moderation (举报系统)
// ────────────────────────────────────────────

model Report {
  id           String       @id @default(uuid())
  reporterId   String
  contentType  ContentType
  contentId    String
  reason       String
  status       ReportStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  resolvedById String?
  resolvedAt   DateTime?
  adminNote    String?

  reporter User  @relation("Reporter", fields: [reporterId], references: [id])
  resolver User? @relation("Resolver", fields: [resolvedById], references: [id])

  @@index([status, createdAt])
  @@index([contentType, contentId])
}

enum ContentType {
  REMINDER
  COMMENT
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

// ────────────────────────────────────────────
// Admin Config & Audit
// ────────────────────────────────────────────

model Config {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String // e.g. "ban_user", "update_config"
  targetType String // e.g. "user", "group", "reminder"
  targetId   String?
  payload    Json?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([action])
}

// ────────────────────────────────────────────
// Attachments — 多用途；"附件"绑在 Reminder 上做"封面.jpg / 0:12 语音"，
// "完成证据"绑在 Completion 上做 HfReminderDetail "收下，发个图"。
// 至少一个 FK 应非空（应用层校验，不在 DB enforce）。
// ────────────────────────────────────────────

model Attachment {
  id           String   @id @default(uuid())
  ownerId      String
  url          String   // 本地路径或 S3 url
  mimeType     String
  bytes        Int
  reminderId   String?
  completionId String?
  createdAt    DateTime @default(now())

  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reminder   Reminder?   @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  completion Completion? @relation(fields: [completionId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([reminderId])
  @@index([completionId])
}
